{
  "name": "woontegra-backend",
  "version": "1.0.0",
  "description": "Woontegra website and panel API",
  "main": "dist/index.js",
  "scripts": {
    "build": "node scripts/prisma-generate.cjs && tsc",
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "admin:ensure": "tsx scripts/ensure-admin.ts",
    "ensure:kasa-saas": "tsx scripts/ensure-muvekkil-kasa-defteri-saas.ts",
    "audit:images": "tsx scripts/audit-image-paths.ts",
    "fix:images": "tsx scripts/fix-upload-image-paths.ts",
    "report:download-delivery": "tsx scripts/report-download-delivery.ts",
    "legal:sync-defaults": "tsx scripts/sync-legal-defaults.ts",
    "postinstall": "node scripts/prisma-generate.cjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.3",
    "playwright": "^1.52.0",
    "prisma": "5.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
