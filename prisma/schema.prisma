// PostgreSQL — Railway: Projeye Postgres plugin ekleyince DATABASE_URL otomatik gelir.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(uuid())
  pageKey   String   @unique
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// WordPress-benzeri tek alan: HTML içerik
model Page {
  id               String                 @id @default(uuid())
  slug             String                 @unique
  title            String
  content          String                 @default("") @db.Text
  /// draft | published
  status           String                 @default("published")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  menuItems        MenuItem[]
  navigationItems  NavigationMenuItem[]
}

model MediaAsset {
  id        String   @id @default(uuid())
  url       String
  filename  String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
}

model PostCategory {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id            String         @id @default(uuid())
  slug          String         @unique
  title         String
  excerpt       String?
  bodyHtml      String?        @db.Text
  featuredImage String?
  status        String         @default("draft")
  publishedAt   DateTime?
  categoryId    String?
  category      PostCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([categoryId])
  @@index([status])
}

model Menu {
  id        String     @id @default(uuid())
  name      String
  location  String     @unique
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id       String     @id @default(uuid())
  menuId   String
  menu     Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label    String
  url      String?
  pageId   String?
  page     Page?      @relation(fields: [pageId], references: [id], onDelete: SetNull)
  order    Int        @default(0)
  parentId String?
  parent   MenuItem?  @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children MenuItem[] @relation("MenuTree")

  @@index([menuId, order])
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  icon        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Brand {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  image       String
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String   @db.Text
  phone     String?
  company   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Çerez tarama çalıştırma kaydı
model CookieScanRun {
  id           String   @id @default(uuid())
  scannedAt    DateTime @default(now())
  baseUrl      String
  status       String   @default("completed")
  pagesTotal   Int      @default(0)
  pagesOk      Int      @default(0)
  pagesFailed  Int      @default(0)
  pageResults  String?  @db.Text
  errorMessage String?
}

/// Tespit edilen çerez / depolama kayıtları (admin düzenlemeleri dahil)
model CookieInventoryItem {
  id                 String   @id @default(uuid())
  uniqueKey          String   @unique
  name               String
  domain             String
  path               String   @default("/")
  provider           String   @default("")
  category           String   @default("unknown")
  purpose            String   @default("")
  duration           String   @default("")
  expiresAt          String?
  maxAgeSeconds      Int?
  source             String
  firstSeenUrl       String
  httpOnly           Boolean  @default(false)
  secure             Boolean  @default(false)
  sameSite           String?
  adminProvider      String?
  adminCategory      String?
  adminPurpose       String?
  adminDurationLabel String?
  lastSeenAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([category])
  @@index([source])
}

enum ProductType {
  DOWNLOAD
  SAAS
  SERVICE
}

/// Mağaza medya kütüphanesi (CMS MediaAsset’tan ayrı)
enum CatalogMediaFileType {
  IMAGE
  DOWNLOAD
  DOCUMENT
}

enum MediaStorageProvider {
  LOCAL
  R2
}

model CatalogMedia {
  id             String               @id @default(uuid())
  fileName       String
  originalName   String
  mimeType       String
  fileType       CatalogMediaFileType
  fileSize      Int
  url            String
  storageKey     String?
  storageProvider MediaStorageProvider @default(LOCAL)
  bucket         String?
  publicUrl      String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  coverProducts  Product[]          @relation("ProductCoverMedia")
  downloadProducts Product[]        @relation("ProductDownloadMedia")
  productGalleryImages ProductGalleryImage[]

  @@index([fileType, createdAt])
}

model ProductCategory {
  id          String              @id @default(uuid())
  name        String
  slug        String              @unique
  description String?             @db.Text
  parentId    String?
  parent      ProductCategory?    @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[]   @relation("CategoryTree")
  isActive    Boolean             @default(true)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    Product[]
  navItems    NavigationMenuItem[]

  @@index([parentId, sortOrder])
  @@index([isActive, sortOrder])
}

enum NavigationMenuItemType {
  CUSTOM_URL
  PRODUCT
  CATEGORY
  PAGE
}

/// Mağaza üst menü (CMS / builder menüsünden bağımsız)
model NavigationMenuItem {
  id           String                   @id @default(uuid())
  label        String
  type         NavigationMenuItemType
  url          String?
  productId    String?
  product      Product?                 @relation(fields: [productId], references: [id], onDelete: SetNull)
  categoryId   String?
  category     ProductCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  pageId       String?
  page         Page?                    @relation(fields: [pageId], references: [id], onDelete: SetNull)
  parentId     String?
  parent       NavigationMenuItem?      @relation("NavMenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     NavigationMenuItem[]     @relation("NavMenuTree")
  sortOrder    Int                      @default(0)
  isActive     Boolean                  @default(true)
  openInNewTab Boolean                  @default(false)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([parentId, sortOrder])
  @@index([isActive, sortOrder])
}

/// Mağaza / indirilebilir ürün (ödeme bu fazda yok)
/// Mağaza müşteri hesabı (panel girişi; admin User ile karışmaz)
model Customer {
  id           String             @id @default(uuid())
  name         String
  email        String             @unique
  passwordHash String
  phone        String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  addresses    CustomerAddress[]
  favorites    CustomerFavorite[]
  orders       Order[]
  licenses     License[]
  saasMemberships CustomerSaasMembership[]
}

model CustomerAddress {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title       String
  fullName    String
  phone       String?
  city        String
  district    String?
  addressLine String   @db.Text
  postalCode  String?
  taxOffice   String?
  taxNumber   String?
  companyName String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
}

model CustomerFavorite {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
}

enum CustomerSaasMembershipStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

/// Woontegra Website müşteri hesabına bağlı SaaS üyelik kaydı (MK SaaS provision sonrası).
model CustomerSaasMembership {
  id               String                       @id @default(uuid())
  customerId       String
  customer         Customer                     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId        String?
  product          Product?                     @relation(fields: [productId], references: [id], onDelete: SetNull)
  productCode      String
  tenantId         String                       @unique
  tenantSlug       String
  licenseKey       String
  ownerEmail       String
  status           CustomerSaasMembershipStatus @default(ACTIVE)
  licenseStartDate DateTime
  licenseEndDate   DateTime
  firstOrderId     String                       @unique
  lastOrderId      String
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  renewalOrderItems OrderItem[]

  @@unique([customerId, productCode, tenantId])
  @@index([customerId])
  @@index([customerId, productCode, status])
}

model Product {
  id                  String           @id @default(uuid())
  name                String
  slug                String           @unique
  productType         ProductType      @default(DOWNLOAD)
  shortDescription    String           @default("") @db.Text
  description         String           @default("") @db.Text
  price               Decimal          @db.Decimal(12, 2)
  compareAtPrice      Decimal?         @db.Decimal(12, 2)
  currency            String           @default("TRY")
  isActive            Boolean          @default(true)
  /// SAAS vb.: false iken sepete eklenemez; DOWNLOAD için varsayılan true
  purchaseEnabled     Boolean          @default(true)
  /// Yıllık lisans ay sayısı (SaaS); masaüstü ürünlerde bilgi amaçlı
  licenseMonths       Int              @default(12)
  /// Merkezi Woontegra-Lisans-Server üzerinden lisans üretilsin mi
  licenseRequired     Boolean          @default(false)
  /// MUVEKKIL_KASA_DESKTOP vb. — Woontegra-Lisans-Server program kodu
  licenseAppCode      String?
  /// Lisans süresi (gün); licenseRequired=true iken kullanılır
  licenseDays         Int              @default(365)
  /// Maksimum cihaz; licenseRequired=true iken kullanılır
  licenseMaxDevices   Int              @default(1)
  /// Her satır bir madde; public ürün detayında listelenir
  featureBullets      String           @default("") @db.Text
  isFeatured          Boolean          @default(false)
  sortOrder           Int              @default(0)
  version             String?
  coverImage          String?
  downloadUrl         String?
  /// Çoklu R2 indirme dosyaları (setup/portable vb.) — JSON: { version, publicFreeDownload, showAfterPaymentOnly, files[] }
  downloadFiles       Json?
  categoryId          String?
  category            ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  seoTitle            String?
  seoDescription      String?          @db.Text
  coverImageMediaId   String?
  coverImageMedia     CatalogMedia?    @relation("ProductCoverMedia", fields: [coverImageMediaId], references: [id], onDelete: SetNull)
  downloadMediaId     String?
  downloadMedia       CatalogMedia?    @relation("ProductDownloadMedia", fields: [downloadMediaId], references: [id], onDelete: SetNull)
  galleryImages       ProductGalleryImage[]
  orderItems          OrderItem[]
  favoritedBy         CustomerFavorite[]
  licenses            License[]
  saasMemberships     CustomerSaasMembership[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  navigationItems     NavigationMenuItem[]

  @@index([isActive, sortOrder])
  @@index([slug])
  @@index([categoryId])
}

enum OrderStatus {
  PENDING
  /// Havale/EFT admin onayı sonrası; ödeme alındı, teslimat süreci
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum PaymentProvider {
  PAYTR
  BANK_TRANSFER
}

enum PaymentTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum LicenseLifecycleStatus {
  ACTIVE
  DISABLED
  EXPIRED
}

enum LicenseSource {
  MANUAL
  WEBSITE_ORDER
}

enum LicenseActivationStatus {
  ACTIVE
  REVOKED
}

enum LegalDocumentType {
  PRE_INFORMATION
  DISTANCE_SALES
  KVKK_CLARIFICATION
  EXPLICIT_CONSENT
  COMMERCIAL_ELECTRONIC_MESSAGE
  TERMS_OF_USE
  PRIVACY_POLICY
  /// Masaüstü / DOWNLOAD ürün yazılım lisans sözleşmesi
  SOFTWARE_LICENSE
  /// SaaS abonelik ve kullanım sözleşmesi
  SAAS_SUBSCRIPTION
  /// Dijital teslim / hizmet başlangıcı ve cayma hakkı istisnası onayı
  DIGITAL_IMMEDIATE_DELIVERY_WAIVER
}

/// Havale/EFT — vitrinde gösterilecek banka bilgisi (tek satır; admin CRUD sonrası genişletilebilir)
model BankTransferSettings {
  id            String   @id
  isPublished   Boolean  @default(false)
  bankName      String   @default("")
  branchName    String   @default("")
  accountNumber String   @default("")
  accountHolder String   @default("")
  iban          String   @default("")
  currency      String   @default("TRY")
  referenceNote String   @default("") @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// PayTR mağaza ayarları (tek satır PAYTR)
model PaymentSettings {
  id                    String          @id @default(uuid())
  provider              PaymentProvider @unique
  isActive              Boolean         @default(false)
  testMode              Boolean         @default(true)
  merchantId            String          @default("")
  merchantKeyEncrypted  String          @default("")
  merchantSaltEncrypted String          @default("")
  callbackUrl           String?
  successUrl            String?
  failUrl               String?
  debugOn               Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

/// CMS yasal metinler (ön bilgilendirme, mesafeli satış, KVKK vb.)
model LegalDocument {
  id        String            @id @default(uuid())
  type      LegalDocumentType
  title     String
  content   String            @db.Text
  version   Int               @default(1)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([type, isActive])
}

model Order {
  id                        String        @id @default(uuid())
  customerId                String?
  customer                  Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderNo                   String        @unique
  customerName              String
  customerEmail             String
  customerPhone             String?
  billingType               String?
  taxOffice                 String?
  taxNumber                 String?
  companyName               String?
  status                    OrderStatus   @default(PENDING)
  paymentProvider           PaymentProvider @default(PAYTR)
  subtotal                  Decimal       @db.Decimal(12, 2)
  total                     Decimal       @db.Decimal(12, 2)
  currency                  String        @default("TRY")
  paidAt                    DateTime?
  /// Havale/EFT: bankaya geçen ödeme tarihi (admin girişi)
  bankTransferPaymentDate   DateTime?
  bankTransferAdminNote     String?       @db.Text
  bankTransferReference     String?       @db.VarChar(500)
  paymentConfirmedAt        DateTime?
  paymentConfirmedById      String?
  downloadEmailSentAt       DateTime?
  preInfoAcceptedAt         DateTime?
  distanceSalesAcceptedAt   DateTime?
  kvkkReadAt                DateTime?
  softwareLicenseAcceptedAt DateTime?
  saasSubscriptionAcceptedAt DateTime?
  digitalProductWaiverAcceptedAt DateTime?
  digitalServiceWaiverAcceptedAt DateTime?
  /// Sipariş anındaki ürün tipleri (ör. DOWNLOAD,SAAS) — yasal onay kapsamı
  legalCartProductTypes     String?
  marketingConsentAt        DateTime?
  explicitConsentAt         DateTime?
  acceptedIp                String?
  acceptedUserAgent         String?
  /// Admin iç notu (müşteri görmez)
  adminNote                 String?       @db.Text
  shippingCarrier           String?       @db.VarChar(200)
  shippingTrackingNumber    String?       @db.VarChar(200)
  shippingStatus            String?       @db.VarChar(120)
  /// Soft delete: arşivlenmiş siparişler listede gösterilmez
  archivedAt                DateTime?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  items                     OrderItem[]
  paymentTransactions       PaymentTransaction[]
  legalSnapshots            OrderLegalSnapshot[]
  legalArchiveFiles         OrderLegalArchiveFile[]
  licenses                  License[]

  @@index([status, createdAt])
  @@index([customerEmail])
  @@index([customerId])
  @@index([archivedAt])
}

/// Sipariş anında kabul edilen yasal metin anlık görüntüsü
model OrderLegalSnapshot {
  id           String            @id @default(uuid())
  orderId      String
  order        Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  documentType LegalDocumentType
  title        String
  content      String             @db.Text
  version      Int
  acceptedAt   DateTime          @default(now())
  ipAddress    String?
  userAgent    String?

  @@index([orderId])
  @@index([documentType])
}

/// Sipariş yasal arşivi (PDF / acceptance.json) — Faz 3A
model OrderLegalArchiveFile {
  id             String             @id @default(uuid())
  orderId        String
  order          Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  packageNo      String
  documentType   LegalDocumentType?
  fileCategory   String
  title          String
  fileName       String
  storageKey     String
  mimeType       String
  size           Int
  sha256         String
  acceptanceCode String?
  version        Int?
  generatedAt    DateTime           @default(now())

  @@unique([orderId, fileName])
  @@index([orderId])
  @@index([packageNo])
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName  String
  productSlug  String?
  unitPrice    Decimal  @db.Decimal(12, 2)
  quantity     Int      @default(1)
  total        Decimal  @db.Decimal(12, 2)
  downloadUrl  String?
  licenses     License[]
  /// Merkezi lisans sunucusuna bildirilen adet (idempotency)
  licenseServerUnitsNotified Int      @default(0)
  licenseServerLastError     String?  @db.Text
  licenseServerLastNotifiedAt DateTime?
  /// Merkezi lisans sunucusundan dönen anahtar (mail yeniden denemesi için)
  licenseServerLicenseKey    String?
  /// Mail gönderilene kadar tutulur; gönderim sonrası silinir
  licenseServerActivationPasswordPending String? @db.Text
  /// SaaS üyelik yenileme satırı — dolu ise provision değil renew akışı
  saasMembershipId String?
  saasMembership   CustomerSaasMembership? @relation(fields: [saasMembershipId], references: [id], onDelete: SetNull)
  saasRenewalDays  Int?

  @@index([orderId])
  @@index([saasMembershipId])
}

/// Sipariş satırı başına (adet kadar) veya admin manuel — masaüstü / indirilebilir ürün lisansı
model License {
  id                     String                 @id @default(uuid())
  licenseKey             String                 @unique
  activationPasswordHash String?
  orderId                String?
  order                  Order?                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderNo                String?
  orderItemId            String?
  orderItem              OrderItem?             @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  unitIndex              Int?
  customerId             String?
  customer               Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName           String?
  customerEmail          String
  customerPhone          String?
  productId              String?
  product                Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName            String
  productCode            String?
  source                 LicenseSource          @default(WEBSITE_ORDER)
  status                 LicenseLifecycleStatus @default(ACTIVE)
  maxDevices             Int                    @default(1)
  startsAt               DateTime?
  expiresAt              DateTime?
  notes                  String?                @db.Text
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  activations            LicenseActivation[]

  @@unique([orderItemId, unitIndex])
  @@index([orderId])
  @@index([orderNo])
  @@index([customerEmail])
  @@index([source])
  @@index([productCode])
}

model LicenseActivation {
  id               String                 @id @default(uuid())
  licenseId        String
  license          License                @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  deviceHash       String
  deviceName       String?
  platform         String?
  appVersion       String?
  firstActivatedAt DateTime               @default(now())
  lastValidatedAt  DateTime?
  status           LicenseActivationStatus @default(ACTIVE)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([licenseId, deviceHash])
  @@index([licenseId])
}

model PaymentTransaction {
  id                  String                   @id @default(uuid())
  orderId             String
  order               Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider            PaymentProvider          @default(PAYTR)
  merchantOid         String                   @unique
  status              PaymentTransactionStatus @default(PENDING)
  amount              Decimal                  @db.Decimal(12, 2)
  currency            String                   @default("TRY")
  providerRawPayload  Json?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([orderId])
  @@index([status])
}

model DownloadLog {
  id             String   @id @default(uuid())
  orderId        String?
  productId      String?
  customerEmail  String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

/// Ürün vitrin galerisi (yalnızca IMAGE medya; kapak ayrı alanda kalır)
model ProductGalleryImage {
  id         String       @id @default(uuid())
  productId  String
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaId    String
  media      CatalogMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([productId, mediaId])
  @@index([productId, sortOrder])
}

/// Ürün indirme sayaçları — productKey + variant başına tek kayıt
model DownloadStat {
  id         String   @id @default(uuid())
  productKey String
  /// setup | portable
  variant    String
  count      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productKey, variant])
  @@index([productKey])
}
