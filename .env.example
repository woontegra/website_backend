# ÖNEMLİ: .env Git'e gitmez. Railway'de Variables'a da ekleyin.

# ——— Zorunlu (production) ———
NODE_ENV=production
PORT=4000
JWT_SECRET=uzun-guclu-gizli-anahtar
# Virgülle ayırın:
CORS_ORIGIN=https://woontegra.com,https://www.woontegra.com

# ——— Veritabanı (Prisma) ———
# Railway Postgres → Connect → Public Network → "Database URL"
DATABASE_PUBLIC_URL="postgresql://postgres:SIFRE@xxx.proxy.rlwy.net:PORT/railway?sslmode=require"
# İsteğe bağlı iç ağ (deploy içinden daha hızlı):
# DATABASE_URL="postgresql://postgres:...@postgres.railway.internal:5432/railway"

# Local Woontegra-Lisans-Server (masaüstü ürün satışı sonrası)
# LICENSE_SERVER_URL=http://localhost:4000
# LICENSE_SERVER_INTEGRATION_SECRET=change-me-integration-secret

# SMTP (admin panel test e-postası için)
# GMAIL_APP_PASSWORD=xxxx
# Cloudinary (legacy upload; kurumsal site görselleri frontend asset)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Çerez tarama tabanı (admin cookie scan)
# COOKIE_SCAN_BASE_URL=https://woontegra.com

# ——— Yalnızca local/preview smoke ———
# Production'da TANIMLAMAYIN (kod yok sayar ama risk oluşturur)
# SMOKE_TEST_MODE=true

# PayTR anahtarlarını DB’de şifreli saklamak için (32 bayt hex veya base64; yoksa JWT_SECRET kullanılır)
# PAYMENT_ENCRYPTION_KEY=
# Sipariş yasal metin placeholder’ları ({{sellerTitle}} vb.)
# SELLER_LEGAL_TITLE=Woontegra
# SELLER_LEGAL_EMAIL=info@woontegra.com
# SELLER_LEGAL_PHONE=
# SELLER_LEGAL_ADDRESS=
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# PAYTR_TEST_MODE=true
# PAYTR_DEBUG_ON=true
# Mağaza panelindeki Bildirim URL ile aynı olmalı (POST, herkese açık):
# PAYTR_CALLBACK_URL=https://api.siteniz.com/api/payments/paytr/callback
# Ödeme sonrası müşteri yönlendirmesi (bilgilendirme; onay callback ile):
# FRONTEND_SUCCESS_URL=https://www.siteniz.com/siparis-basarili
# FRONTEND_FAIL_URL=https://www.siteniz.com/siparis-basarisiz
# Sipariş onayı e-postasındaki göreli linkler:
# — `/uploads/...` → BACKEND_PUBLIC_URL ile birleştirilir (zorunlu production).
# — Diğer göreli yollar → PUBLIC_SITE_URL / FRONTEND_URL / CORS kökeni.
# FRONTEND_URL=https://www.siteniz.com
# PUBLIC_SITE_URL=https://www.siteniz.com

# Mağaza katalog ZIP’leri backend’de `/uploads/...` altında. Ödeme mailindeki İndir linki
# mutlaka bu köke gider (frontend değil). Sonunda /api YOK.
# Local: http://localhost:4000   |   Railway: https://xxx.up.railway.app
BACKEND_PUBLIC_URL=https://woontegra-commerce-backend-production.up.railway.app

# ——— Cloudflare R2 (public medya + private indirmeler) ———
# Public görseller: logo, ürün, kategori, banner, builder, blog, medya kütüphanesi
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_BUCKET_NAME=woontegra-media
R2_PRIVATE_BUCKET_NAME=woontegra-downloads
R2_PUBLIC_BASE_URL=

# İsteğe bağlı: API_PUBLIC_URL veya Railway’de RAILWAY_PUBLIC_DOMAIN (https eklenir)
