# ÖNEMLİ: .env sadece BİLGİSAYARINIZDA (npm run dev) okunur.
# .env Git’e ve Railway’e GİTMEZ (.gitignore). Railway’de aynı değişkenleri
# Dashboard → Backend servisi → Variables içine TEKRAR eklemeniz gerekir.

# ——— Genel ———
PORT=4000
JWT_SECRET=uzun-ve-guclu-bir-gizli-anahtar-en-az-32-karakter
# Frontend adresi (Railway/Vercel domain’iniz)
CORS_ORIGIN=https://siteniz.railway.app

# ——— Railway PostgreSQL ———
# Railway’de: New → Database → PostgreSQL oluşturun.
# Backend servisinizde: Variables → "Add Reference" → Postgres → DATABASE_URL seçin.
# Böylece DATABASE_URL otomatik dolar (iç ağ: postgres.railway.internal, SSL gerekmez).
#
# Yerel geliştirme için Postgres servisinin "Connect" / Public Network sekmesindeki
# "Connection URL" değerini kopyalayın. Bağlantı hatası alırsanız sona ekleyin:
#   ?sslmode=require
#
# Örnek (public proxy — Railway arayüzünden kopyalanır):
# DATABASE_URL="postgresql://postgres:ŞİFRE@trolley.proxy.rlwy.net:12345/railway?sslmode=require"

DATABASE_URL=postgresql://postgres:TJDplaSiRZPFgboGzNGOGJuihKNZfzfs@postgres.railway.internal:5432/railway
