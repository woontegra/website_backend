# ÖNEMLİ: .env Git’e gitmez. Railway’de Variables’a da ekleyin.

PORT=4000
JWT_SECRET=uzun-guclu-gizli-anahtar
CORS_ORIGIN=http://localhost:5173

# ——— Veritabanı (aynı DB: lokal + canlı) ———
# Railway Postgres → Connect → Public Network → “Database URL”
# Sadece bunu kullanabilirsiniz (Prisma otomatik DATABASE_URL’e çevirir):
DATABASE_PUBLIC_URL="postgresql://postgres:SIFRE@xxx.proxy.rlwy.net:PORT/railway?sslmode=require"

# İsteğe bağlı: Railway içinden deploy’da iç ağ (postgres.railway.internal) daha hızlıdır.
# Tanımlıysa önce bu okunur; yoksa DATABASE_PUBLIC_URL kullanılır.
# DATABASE_URL="postgresql://postgres:...@postgres.railway.internal:5432/railway"

# ——— Cloudinary (ZORUNLU — kurumsal site görsel yüklemeleri) ———
# Tanımsızsa panel yüklemesi reddedilir; /uploads fallback kullanılmaz (Railway geçici disk).
# Cloudinary Dashboard → Programmable Media → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# CLOUDINARY_FOLDER=woontegra
